# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL 連線字串，推薦使用 Vercel Postgres 或 Supabase
# Vercel Postgres 部署後會自動注入此變數
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Auth ───────────────────────────────────────────────────────────────────────
# 用 openssl rand -base64 32 產生隨機字串
NEXTAUTH_SECRET=your-random-secret-here
JWT_SECRET=your-random-jwt-secret-here

# ── App URL ────────────────────────────────────────────────────────────────────
# Vercel 部署後的網址，例如 https://ptt-alertor.vercel.app
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# ── Cron 保護 ──────────────────────────────────────────────────────────────────
# 隨機字串，防止外部直接觸發爬蟲 API
# 用 openssl rand -base64 32 產生
CRON_SECRET=your-cron-secret-here

# ── Email 通知（選填）─────────────────────────────────────────────────────────
# 至 https://sendgrid.com 申請免費帳號（每日 100 封免費）
SENDGRID_API_KEY=SG.xxxxxx

# ── Stripe 付費功能（選填，不需付費功能可先不填）────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxx
STRIPE_LIGHT_PRICE_ID=price_xxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxx
